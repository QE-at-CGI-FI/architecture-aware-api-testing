meta {
  name: GET nodes filter level 1
  type: http
  seq: 8
}

get {
  url: http://localhost:8000/nodes?level=1
  body: none
  auth: none
}

tests {
  test("returns 11 nodes", function() {
    expect(res.body).to.have.lengthOf(11);
  });
  test("all are level 1", function() {
    res.body.forEach(n => {
      expect(n.level).to.equal(1);
    });
  });
}
