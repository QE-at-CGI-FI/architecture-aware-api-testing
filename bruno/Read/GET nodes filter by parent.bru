meta {
  name: GET nodes filter by parent
  type: http
  seq: 10
}

get {
  url: http://localhost:8000/nodes?parent_id=user-interface-errors
  body: none
  auth: none
}

tests {
  test("returns results", function() {
    expect(res.body.length).to.be.above(0);
  });
  test("all have correct parent_id", function() {
    res.body.forEach(n => {
      expect(n.parent_id).to.equal('user-interface-errors');
    });
  });
}
