meta {
  name: GET nodes filter level 4
  type: http
  seq: 9
}

get {
  url: http://localhost:8000/nodes?level=4
  body: none
  auth: none
}

tests {
  test("returns results", function() {
    expect(res.body.length).to.be.above(0);
  });
  test("all are level 4", function() {
    res.body.forEach(n => {
      expect(n.level).to.equal(4);
    });
  });
}
